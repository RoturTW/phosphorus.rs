name: Array Function

code (program):
    event(onload) {
        numbers := [1,2,3];
        log(length(numbers));
        log(length([]));
        log(item(numbers, 2));
        log(item(numbers, 0));
        log(range(1, 5));
        log(range(0, 2));
    }

result:
    3 0 3 1 [1, 2, 3, 4, 5] [0, 1, 2]